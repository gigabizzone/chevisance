# ─── Chevisance Shipping — Environment Variable Template ───────────────────
# Copy this file to `.env.local` and fill in real values.

# Resend email API key — https://resend.com (free tier: 100 emails/day)
RESEND_API_KEY=

# Address that receives form notifications (client's inbox)
CONTACT_EMAIL=

# Verified sender address in Resend (must be on a verified domain)
RESEND_FROM_EMAIL=

# Public site URL — used by metadata, sitemap, robots, JSON-LD
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
